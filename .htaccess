RewriteEngine On

# Rutas limpias para formularios de investigación
RewriteRule ^animal/cuidado/?$ /cuidado/animal [R=301,L]
RewriteRule ^cuidado/animal/?$ /public/analytics/animal/cuidado.html [L]
RewriteRule ^cuidado/animal/privacidad/?$ /public/analytics/animal/privacidad.html [L]
RewriteRule ^cuidado/animal/tratamiento-datos/?$ /public/analytics/animal/tratamiento-datos.html [L]
RewriteRule ^tours/?$ /public/analytics/tours/index.html [L]
RewriteRule ^tours/privacidad/?$ /public/analytics/tours/privacidad.html [L]
RewriteRule ^lalia/?$ /portafolio/proyectos/lalia/index.html [L]

# Quitar extensión .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# Forzar /experiencia/ a cargar el index.html interno si existe
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]
